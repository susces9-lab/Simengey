    addLog("Логи очищены", Color3.fromRGB(255, 165, 0))
end)

-- ==================================================
-- DISCORD ФУНКЦИИ
-- ==================================================
local function sendToDiscord(embedData)
    local data = {
        embeds = {embedData}
    }
    
    local success, err = pcall(function()
        HttpService:PostAsync(DISCORD_WEBHOOK_URL, HttpService:JSONEncode(data))
    end)
    
    if success then
        addLog("✅ Отправлено в Discord: " .. (embedData.title or "уведомление"), Color3.fromRGB(0, 255, 0))
        return true
    else
        addLog("❌ Ошибка отправки: " .. tostring(err), Color3.fromRGB(255, 0, 0))
        return false
    end
end

-- Тестовая отправка
testBtn.MouseButton1Click:Connect(function()
    addLog("📨 Отправка тестового сообщения...", Color3.fromRGB(255, 255, 0))
    sendToDiscord({
        title = "🧪 ТЕСТОВОЕ СООБЩЕНИЕ",
        description = "Скрипт работает и соединение с Discord установлено!\n**Игрок:** " .. player.Name,
        color = 0x57F287,
        footer = {text = "Время: " .. os.date("%Y-%m-%d %H:%M:%S")}
    })
end)

-- ==================================================
-- ОСНОВНАЯ ЛОГИКА ЛОГГЕРА
-- ==================================================
local inventory = player:FindFirstChild("Inventory") or player:FindFirstChild("Data") or player:FindFirstChild("Backpack")

if not inventory then
    addLog("⚠️ Папка инвентаря не найдена!", Color3.fromRGB(255, 165, 0))
    sendToDiscord({
        title = "⚠️ Ошибка инициализации",
        description = "Папка инвентаря не найдена. Скрипт может работать некорректно.",
        color = 0xED4245
    })
end

-- Отправляем приветственное сообщение
local welcomeSent = sendToDiscord({
    title = "🤖 SWILL Logger активирован",
    description = "Отслеживание инвентаря запущено\n**Игрок:** " .. player.Name,
    color = 0x57F287,
    footer = {text = "Время: " .. os.date("%Y-%m-%d %H:%M:%S")}
})
updateConnectionStatus(welcomeSent)

local previousCounts = {}

local function checkInventory()
    if not inventory then return end
    
    for _, item in pairs(inventory:GetChildren()) do
        local itemName = item.Name
        
        local isTracked = false
        for _, tracked in ipairs(trackedItems) do
            if itemName:find(tracked) then
                isTracked = true
                break
            end
        end
        
        if isTracked then
            local currentValue = 0
            if item:IsA("IntValue") or item:IsA("NumberValue") then
                currentValue = item.Value
            end
            
            local previousValue = previousCounts[itemName] or 0
            
            if currentValue > previousValue then
                local gained = currentValue - previousValue
                addLog("📦 +" .. gained .. " " .. itemName, Color3.fromRGB(0, 255, 0))
                sendToDiscord({
                    title = "📦 ПОЛУЧЕН ПРЕДМЕТ!",
                    description = string.format(
                        "**Предмет:** %s\n**Получено:** +%d шт.\n**Теперь:** %d шт.",
                        itemName, gained, currentValue
                    ),
                    color = 0x57F287,
                    footer = {text = "Игрок: " .. player.Name}
                })
            end
            
            previousCounts[itemName] = currentValue
        end
    end
end

-- Запуск проверки
spawn(function()
    if inventory then
        for _, item in pairs(inventory:GetChildren()) do
            if item:IsA("IntValue") or item:IsA("NumberValue") then
                previousCounts[item.Name] = item.Value
            end
        end
    end
    
    while true do
        wait(2)
        checkInventory()
    end
end)

if inventory then
    inventory.ChildAdded:Connect(function(child)
        local itemName = child.Name
        
        local isTracked = false
        for _, tracked in ipairs(trackedItems) do
            if itemName:find(tracked) then
                isTracked = true
                break
            end
        end
        
        if isTracked then
            local value = ""
            if child:IsA("IntValue") or child:IsA("NumberValue") then
                value = tostring(child.Value) .. " шт."
                previousCounts[itemName] = child.Value
            else
                value = "получен!"
            end
            
            addLog("🎉 Новый предмет: " .. itemName, Color3.fromRGB(100, 255, 100))
            sendToDiscord({
                title = "🎉 НОВЫЙ ПРЕДМЕТ!",
                description = string.format("**Предмет:** %s\n**Количество:** %s", itemName, value),
                color = 0x57F287,
                footer = {text = "Игрок: " .. player.Name}
            })
        end
    end)
end

addLog("🟢 SWILL LOGGER ЗАПУЩЕН", Color3.fromRGB(0, 255, 0))
addLog("📡 Отслеживается " .. #trackedItems .. " предметов", Color3.fromRGB(255, 255, 255))
addLog("👤 Игрок: " .. player.Name, Color3.fromRGB(255, 255, 255))

print("✅ SWILL LOGGER GUI ЗАГРУЖЕН")
