-- ==================================================
-- ФУНКЦИИ GUI
-- ==================================================
local function addLog(msg, color)
    local time = os.date("%H:%M:%S")
    table.insert(logMessages, 1, "[" .. time .. "] " .. msg)
    if #logMessages > 50 then table.remove(logMessages) end
    
    local display = ""
    for i = #logMessages, 1, -1 do
        display = display .. logMessages[i] .. "\n"
    end
    logText.Text = display
    logFrame.CanvasSize = UDim2.new(0, 0, 0, #logMessages * 25)
end

local function updateStatus(text, color)
    statusLabel.Text = text
    statusLabel.TextColor3 = color
    addLog("📡 " .. text, color)
end

local function updateConnectionStatus(success)
    if success then
        connectionStatus = "✅ ПОДКЛЮЧЕНО"
        statusBar.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        miniStatus.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        updateStatus("✅ Discord: подключено", Color3.fromRGB(0, 255, 0))
    else
        connectionStatus = "❌ ОШИБКА"
        statusBar.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        miniStatus.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        updateStatus("❌ Discord: ошибка подключения", Color3.fromRGB(255, 0, 0))
    end
end

-- Сворачивание/разворачивание
